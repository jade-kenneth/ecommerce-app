{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",

    "strict": true,
    "noEmit": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "~/components/*": ["./src/libs/components/*"],
      "~/constants": ["./src/libs/constant.ts"],
      "~/contexts/*": ["./src/libs/contexts/*"],
      "~/config/*": ["./src/libs/config/*"],
      "~/providers/*": ["./src/libs/providers/*"],
      "~/features/*": ["./src/libs/features/*"],
      "~/graphql/*": ["./src/libs/graphql/*"],
      "~/theme/*": ["./src/libs/theme/*"],
      "~/utils/*": ["./src/libs/utils/*"],
      "~/icons/*": ["./src/libs/icons/*"],
      "~/hooks/*": ["./src/libs/hooks/*"],

      "~/store": ["./src/libs/store/store.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",

    "../../apps/ecommerce-app/.next/types/**/*.ts",
    "../../dist/apps/ecommerce-app/.next/types/**/*.ts",

    "next-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "jest.config.ts",
    "jest.config.cts",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
