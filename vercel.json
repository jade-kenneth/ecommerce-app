{
  "version": 2,
  "build": {
    "installCommand": "npm install --legacy-peer-deps",
    "buildCommand": "npm run build:server"
  },
  "builds": [
    {
      "src": "apps/ecommerce-server/src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/ecommerce-server/src/main.ts",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"]
    }
  ]
}
