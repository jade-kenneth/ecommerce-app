{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["dom", "dom.iterable", "ESNext"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "~/components/*": ["./src/libs/components/*"],
      "~/constants": ["./src/libs/constant.ts"],
      "~/contexts/*": ["./src/libs/contexts/*"],
      "~/config/*": ["./src/libs/config/*"],
      "~/providers/*": ["./src/libs/providers/*"],
      "~/features/*": ["./src/libs/features/*"],
      "~/graphql/*": ["./src/libs/graphql/*"],
      "~/theme/*": ["./src/libs/theme/*"],
      "~/utils/*": ["./src/libs/utils/*"],
      "~/icons/*": ["./src/libs/icons/*"],
      "~/hooks/*": ["./src/libs/hooks/*"],

      "~/store": ["./src/libs/store/store.ts"]
    },
    "types": ["jest", "node"],
    "target": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "../../apps/ecommerce-app/.next/types/**/*.ts",
    "../../dist/apps/ecommerce-app/.next/types/**/*.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "tailwind.config.js"
  ],
  "exclude": ["node_modules", "jest.config.ts", "**/*.spec.ts", "**/*.test.ts"]
}
