{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@backoffice/admin": ["libs/admin/src/index.ts"],
      "@backoffice/layout": ["libs/admin/src/admin-layout/index.ts"],
      "@ecommerce-app/globally": ["libs/globally/src/index.ts"],
      "@ecommerce-app/globally/server": ["libs/globally/src/server.ts"],
      "@ecommerce-app/object-shared": ["libs/object-shared/src/index.ts"],
      "@ecommerce/object-id": ["libs/object-id/src/index.ts"],
      "@global": ["libs/general/src/index.ts"],
      "@global/server": ["libs/general/src/server.ts"],
      "@graphql/generated": ["libs/general/src/graphql/generated.tsx"],

      "@portal/auth": ["libs/portal/auth/src/index.ts"],
      "@portal/layout": ["libs/portal/layout/src/index.ts"],
      "@portal/theme": ["libs/portal/theme/src/index.ts"],
      "@utils": ["libs/general/src/utils/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
